<Window x:Class="SQLsense.UI.Completion.CompletionWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Height="220"
             WindowStyle="None"
             AllowsTransparency="True"
             Background="White"
             BorderBrush="#007ACC"
             BorderThickness="1"
             ShowInTaskbar="False"
             Topmost="True"
             ShowActivated="False"
             Focusable="False"
             SizeToContent="Height"
             MaxHeight="250">
    <Window.Resources>
        <!-- Style to remove standard selection highlight and create a subtle focus purely determined by IsSelected -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <ListBox x:Name="CompletionList" 
                 Background="White"
                 BorderThickness="0"
                 Focusable="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <!-- Icon Placeholder -->
                        <Border Width="16" Height="16" CornerRadius="2" Margin="0,0,6,0" Background="{Binding IconColor}">
                            <TextBlock Text="{Binding IconText}" Foreground="White" FontSize="9" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </Border>
                        <TextBlock Text="{Binding Text}" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding Description}" Foreground="#555555" FontSize="11" VerticalAlignment="Center" FontStyle="Italic" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
